PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gst_app
ENABLE_MONGO=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gst_app
POSTGRES_SYNC=false
POSTGRES_SSL=false

# RabbitMQ (set true when RabbitMQ is running; false runs jobs inline)
ENABLE_RABBITMQ=false
RABBITMQ_URL=amqp://localhost:5672

# External GST compliance API (used by POST /gst/verify-and-fetch)
# NOTE: ENABLE_MONGO must be true for this feature, results are stored in MongoDB.
# The app authenticates first (x-api-key + x-api-secret) to obtain an access
# token, then reuses that token for the verify/search calls.
GST_API_BASE_URL=https://test-api.sandbox.co.in
# Optional: override only if the authenticate endpoint differs from {BASE_URL}/authenticate
GST_API_AUTH_URL=
GST_API_KEY=
GST_API_SECRET=
GST_API_VERSION=
GST_API_ACCEPT_CACHE=true

# verify-and-fetch tuning
# Rows per batch/queue message
GST_VERIFY_BATCH_SIZE=50
# Parallel verify/search requests within a single batch
GST_VERIFY_CONCURRENCY=5
# Transient-error (429/5xx/network) retry attempts per request
GST_API_MAX_RETRIES=3
# Base backoff in ms (exponential + jitter)
GST_API_RETRY_BASE_MS=500
