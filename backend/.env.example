PORT=3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/gst_app
ENABLE_MONGO=false

# Loan source table in PostgreSQL (columns: loan_id, gst_no, pan_no by default)
LOAN_TABLE_NAME=loans
LOAN_ID_COLUMN=loan_id
GST_NO_COLUMN=gst_no
PAN_NO_COLUMN=pan_no

# External GST compliance API
GST_API_BASE_URL=https://your-gst-provider.example.com
GST_API_KEY=your_api_key
GST_API_VERSION=v1
GST_API_ACCESS_TOKEN=your_access_token

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gst_app
POSTGRES_SYNC=false
POSTGRES_SSL=false

# RabbitMQ (set true when RabbitMQ is running; false runs jobs inline)
ENABLE_RABBITMQ=false
RABBITMQ_URL=amqp://localhost:5672
