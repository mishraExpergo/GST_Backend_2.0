PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gst_app
ENABLE_MONGO=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gst_app
POSTGRES_SYNC=false
POSTGRES_SSL=false

# RabbitMQ (set true when RabbitMQ is running; false runs jobs inline)
ENABLE_RABBITMQ=false
RABBITMQ_URL=amqp://localhost:5672
